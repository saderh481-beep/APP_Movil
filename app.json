{
  "expo": {
    "name": "SADERH",
    "slug": "saderh-app",
    "version": "1.1.1",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#8B0000",
      "resizeMode": "contain"
    },
    "android": {
      "package": "mx.gob.hidalgo.saderh",
      "minSdkVersion": 31,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8B0000"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ],
      "blockedPermissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "bundleIdentifier": "mx.gob.hidalgo.saderh",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SADERH necesita tu ubicación para registrar la visita técnica.",
        "NSCameraUsageDescription": "SADERH necesita la cámara para tomar evidencias.",
        "NSPhotoLibraryUsageDescription": "SADERH necesita acceso a tu galería para subir evidencias."
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-font",
      "expo-secure-store"
    ],
    "scheme": "saderh",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26192e52-1189-414b-8113-e5364b1dbf8e"
      }
    },
    "owner": "susej",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/26192e52-1189-414b-8113-e5364b1dbf8e"
    }
  }
}
